root FRAME x=0 y=0 w=2200 h=1400 "Erzieherausbildung Lernlandkarte"
title TEXT parent=root x=1100 y=80 w=1700 font=open_sans size=34 align=center color=#1a1a1a "Ausbildungsstoff sichtbar machen: lokale Quellen bleiben lokal, Sinnachsen werden teilbar."
sources FRAME parent=root x=180 y=250 w=360 h=820 fill=#F5F5F5 "1 Quellen"
semesters FRAME parent=root x=590 y=250 w=360 h=820 fill=#F5F5F5 "2 Semester"
modules FRAME parent=root x=1000 y=250 w=500 h=820 fill=#F5F5F5 "3 Module"
axes FRAME parent=root x=1550 y=250 w=420 h=820 fill=#F5F5F5 "4 Sinnachsen"
outputs FRAME parent=root x=1100 y=1160 w=1500 h=150 fill=#1a1a1a "5 Ausgaben"
s1 STICKY parent=sources x=180 y=170 w=220 color=light_blue "iCloud Drive Inbox"
s2 STICKY parent=sources x=180 y=360 w=220 color=light_yellow "Rohdateien nicht committen"
s3 STICKY parent=sources x=180 y=550 w=220 color=light_green "Scanner erzeugt Aggregat"
