se2 STICKY parent=semesters x=180 y=500 w=220 color=cyan "2. Semester: EEG, M01, M02, M06, M08, M16, Prüfung"
m1 STICKY parent=modules x=250 y=130 w=250 color=violet "M03 Person / Identität"
m2 STICKY parent=modules x=250 y=270 w=250 color=violet "M04 Kunstgeschichte"
m3 STICKY parent=modules x=250 y=410 w=250 color=violet "M19 Wissenschaftliches Arbeiten"
m4 STICKY parent=modules x=250 y=550 w=250 color=orange "M02 Psychologie / Neuro"
m5 STICKY parent=modules x=250 y=690 w=250 color=orange "M06 Basiskompetenzen"
m6 STICKY parent=modules x=250 y=830 w=250 color=orange "M08 Pädagogische Felder"
a1 TEXT parent=axes x=210 y=120 w=340 font=plex_sans size=22 align=center color=#333333 "Person ↔ Gesellschaft"
a2 TEXT parent=axes x=210 y=270 w=340 font=plex_sans size=22 align=center color=#333333 "Kunst ↔ Wissenschaft"
a3 TEXT parent=axes x=210 y=420 w=340 font=plex_sans size=22 align=center color=#333333 "Bildung ↔ Therapie"
a4 TEXT parent=axes x=210 y=570 w=340 font=plex_sans size=22 align=center color=#333333 "Theorie ↔ Prüfung"
out1 TEXT parent=outputs x=750 y=75 w=420 font=open_sans size=24 align=center color=#FFFFFF "Vercel Web-App"
out2 TEXT parent=outputs x=1100 y=75 w=420 font=open_sans size=24 align=center color=#FFFFFF "Obsidian Canvas"
out3 TEXT parent=outputs x=1450 y=75 w=420 font=open_sans size=24 align=center color=#FFFFFF "Miro via Schauwerk"
e1 CONNECTOR from=s1 to=se1 shape=elbowed end_cap=arrow "source"
e2 CONNECTOR from=se1 to=m1 shape=elbowed end_cap=arrow "module"
e3 CONNECTOR from=se2 to=m6 shape=elbowed end_cap=arrow "module"
e4 CONNECTOR from=m6 to=a3 shape=elbowed end_cap=arrow "Sinnachse"
e5 CONNECTOR from=a3 to=out1 shape=straight end_cap=arrow "publish"
e6 CONNECTOR from=a3 to=out2 shape=straight end_cap=arrow "think"
e7 CONNECTOR from=a3 to=out3 shape=straight end_cap=arrow "collaborate"
